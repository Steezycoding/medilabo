        {
          "name": "Auth",
          "item": [
            {
              "name": "[GW] Get token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Get the Set-Cookie header from the response",
                      "const setCookieHeader = pm.response.headers.get(\"Set-Cookie\");",
                      "",
                      "let token = null;",
                      "",
                      "// Extract the JWT token from the 'access_token=' key in the Set-Cookie header",
                      "if (setCookieHeader) {",
                      "    // Handle both single cookie and multiple cookies (array or semicolon-separated)",
                      "    const cookies = Array.isArray(setCookieHeader) ? setCookieHeader.join(\"; \") : setCookieHeader;",
                      "    ",
                      "    // Match access_token value (stops at semicolon or end of string)",
                      "    const match = cookies.match(/access_token=([^;]+)/);",
                      "    if (match && match[1]) {",
                      "        token = match[1];",
                      "    }",
                      "}",
                      "",
                      "// Store the token in the environment variable 'bearerToken'",
                      "if (token) {",
                      "    pm.environment.set(\"bearerToken\", token);",
                      "    console.log(\"JWT token successfully extracted from Set-Cookie header and stored in 'bearerToken' environment variable\");",
                      "} else {",
                      "    console.warn(\"No JWT token found in Set-Cookie header under 'access_token=' key\");",
                      "}",
                      "",
                      "// Test to verify the token was successfully stored",
                      "pm.test(\"JWT token is extracted from Set-Cookie header and stored in environment\", function () {",
                      "    pm.expect(token).to.be.a(\"string\").and.not.be.empty;",
                      "    pm.expect(pm.environment.get(\"bearerToken\")).to.eql(token);",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "auth": {
                  "type": "basic",
                  "basic": [
                    {
                      "key": "password",
                      "value": "user",
                      "type": "string"
                    },
                    {
                      "key": "username",
                      "value": "user",
                      "type": "string"
                    }
                  ]
                },
